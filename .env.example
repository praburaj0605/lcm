# Frontend — base URL for FastAPI when the browser calls the API directly (CRM data + JWT auth).
# Use http://127.0.0.1:8000 for local uvicorn / Docker API port mapping.
# Leave empty only if you rely entirely on Vite’s /api proxy to the same host (no VITE_API_BASE_URL).
VITE_API_BASE_URL=http://127.0.0.1:8000
